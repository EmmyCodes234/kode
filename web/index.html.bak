<script>
function toggleFaq(btn) {
  btn.parentElement.classList.toggle('open');
  btn.querySelector('span').textContent = btn.parentElement.classList.contains('open') ? '−' : '+';
}
function copyCmd(btn) {
  const code = btn.parentElement.querySelector('code').textContent;
  navigator.clipboard?.writeText(code).then(() => {
    btn.textContent = 'Copied';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });
}
document.querySelectorAll('.install-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.install-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    document.querySelectorAll('.install-snippet').forEach(s => s.style.display = 'none');
    document.getElementById('snippet-' + tab.dataset.tab).style.display = 'flex';
  });
});
</script>
</body>
</html>
